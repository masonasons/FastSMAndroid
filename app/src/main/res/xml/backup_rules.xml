<?xml version="1.0" encoding="utf-8"?>
<!--
   Excludes the encrypted key material and any DataStore files that would be
   meaningless on another device. Chat data is excluded until we build an
   explicit export path.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="chatback_secure.xml" />
    <exclude domain="database" path="chatback.db" />
    <exclude domain="database" path="chatback.db-journal" />
</full-backup-content>
